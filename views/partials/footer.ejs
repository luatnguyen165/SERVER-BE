<!-- ========================
FLOATING CHAT WIDGET
======================== -->
<div class="chat-widget" id="chatWidget">
    <button class="chat-fab" id="chatFab" onclick="toggleChat()" aria-label="Mở chat">
        <i class="fas fa-comment-dots"></i>
        <span class="chat-badge">1</span>
    </button>
    <div class="chat-popup" id="chatPopup">
        <div class="chat-header">
            <div class="chat-header-info">
                <div class="chat-avatar">
                    <i class="fas fa-headset"></i>
                </div>
                <div>
                    <strong>FB-SYSTEM Support</strong>
                    <span class="chat-status">🟢 Trực tuyến</span>
                </div>
            </div>
            <button class="chat-close" onclick="toggleChat()" aria-label="Đóng chat">
                <i class="fas fa-minus"></i>
            </button>
        </div>
        <div class="chat-body" id="chatBody">
            <div class="chat-msg chat-msg-received">
                <div class="chat-msg-avatar">FB</div>
                <div class="chat-msg-content">
                    <p>👋 Xin chào! Chào mừng bạn đến với <strong>FB-SYSTEM</strong>!</p>
                    <p>Mình có thể giúp gì cho bạn hôm nay?</p>
                    <span class="chat-msg-time">Vừa xong</span>
                </div>
            </div>
            <!-- Quick replies -->
            <div class="chat-quick-replies" id="quickReplies">
                <button class="quick-reply" onclick="sendQuickReply('🚀 Tôi muốn dùng thử FB-SYSTEM')">
                    🚀 Tôi muốn dùng thử
                </button>
                <button class="quick-reply" onclick="sendQuickReply('💰 Báo giá dịch vụ')">
                    💰 Báo giá dịch vụ
                </button>
                <button class="quick-reply" onclick="sendQuickReply('🔧 Hỗ trợ kỹ thuật')">
                    🔧 Hỗ trợ kỹ thuật
                </button>
                <button class="quick-reply" onclick="sendQuickReply('🤖 Tính năng AI Content')">
                    🤖 Tính năng AI Content
                </button>
            </div>
        </div>
        <div class="chat-footer">
            <form class="chat-input-form" id="chatForm" onsubmit="sendMessage(event)">
                <input type="text" id="chatInput" placeholder="Nhập tin nhắn..." autocomplete="off">
                <button type="submit" aria-label="Gửi">
                    <i class="fas fa-paper-plane"></i>
                </button>
            </form>
        </div>
    </div>
</div>

