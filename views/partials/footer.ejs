<button class="back-to-top" id="backToTop" aria-label="Lên đầu trang">
    <i class="fas fa-arrow-up"></i>
</button>

<script>
// Back to top
const backToTop = document.getElementById('backToTop');
window.addEventListener('scroll', () => {
    if (window.scrollY > 300) {
        backToTop.classList.add('visible');
    } else {
        backToTop.classList.remove('visible');
    }
});
backToTop.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
});

// Chat widget
function toggleChat() {
    const popup = document.getElementById('chatPopup');
    const fab = document.getElementById('chatFab');
    popup.classList.toggle('open');
    fab.classList.toggle('active');
}

function sendQuickReply(text) {
    document.getElementById('chatInput').value = text;
    document.getElementById('chatForm').dispatchEvent(new Event('submit'));
}

function sendMessage(e) {
    e.preventDefault();
    const input = document.getElementById('chatInput');
    const msg = input.value.trim();
    if (!msg) return;

    const body = document.getElementById('chatBody');
    const quickReplies = document.getElementById('quickReplies');
    if (quickReplies) quickReplies.style.display = 'none';

    // User message
    const userMsg = document.createElement('div');
    userMsg.className = 'chat-msg chat-msg-sent';
    userMsg.innerHTML = '<div class="chat-msg-content"><p>' + msg.replace(/</g, '<') + '</p><span class="chat-msg-time">Vừa xong</span></div>';
    body.appendChild(userMsg);
    input.value = '';
    body.scrollTop = body.scrollHeight;

    // Auto reply
    setTimeout(() => {
        const reply = document.createElement('div');
        reply.className = 'chat-msg chat-msg-received';
        const replyText = msg.toLowerCase().includes('giá') || msg.toLowerCase().includes('price') || msg.toLowerCase().includes('báo giá') 
            ? 'Cảm ơn bạn đã quan tâm! Bạn có thể xem bảng giá chi tiết tại <a href="/pricing" style="color:var(--primary);text-decoration:underline;">đây</a>. Hoặc để lại số điện thoại, chúng tôi sẽ tư vấn riêng cho bạn nhé! 😊'
            : msg.toLowerCase().includes('dùng thử') || msg.toLowerCase().includes('start') || msg.toLowerCase().includes('bắt đầu')
            ? 'Tuyệt vời! 🎉 Bạn có thể đăng ký dùng thử miễn phí 7 ngày tại <a href="/register" style="color:var(--primary);text-decoration:underline;">đây</a>. Hoàn toàn không cần thẻ tín dụng!'
            : msg.toLowerCase().includes('kỹ thuật') || msg.toLowerCase().includes('support') || msg.toLowerCase().includes('hỗ trợ')
            ? 'Bạn gặp vấn đề gì ạ? Đội ngũ kỹ thuật của chúng tôi sẽ hỗ trợ bạn ngay lập tức. Hãy mô tả chi tiết vấn đề bạn đang gặp phải nhé! 🔧'
            : msg.toLowerCase().includes('ai') || msg.toLowerCase().includes('content')
            ? 'Tính năng AI Content của chúng tôi có thể tự động tạo nội dung bài viết, caption, hashtag phù hợp với phong cách của bạn. Bạn có thể xem chi tiết tại <a href="/features/ai-content" style="color:var(--primary);text-decoration:underline;">đây</a> 🤖'
            : 'Cảm ơn bạn đã quan tâm! Để được tư vấn chi tiết, bạn vui lòng để lại số điện thoại hoặc email, chúng tôi sẽ liên hệ lại trong vòng 24h. Hoặc bạn có thể gọi hotline: <strong>1900 xxxx</strong> 📞';
        reply.innerHTML = '<div class="chat-msg-avatar">FB</div><div class="chat-msg-content"><p>' + replyText + '</p><span class="chat-msg-time">Vừa xong</span></div>';
        body.appendChild(reply);
        body.scrollTop = body.scrollHeight;
    }, 1000);
}

// Scroll animations
function handleScrollAnimations() {
    document.querySelectorAll('.animate-on-scroll').forEach(el => {
        const rect = el.getBoundingClientRect();
        if (rect.top < window.innerHeight - 100 && !el.classList.contains('visible')) {
            el.classList.add('visible');
        }
    });
}
window.addEventListener('scroll', handleScrollAnimations);
document.addEventListener('DOMContentLoaded', handleScrollAnimations);
handleScrollAnimations();

// Smooth scroll for anchor links
document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function(e) {
        const href = this.getAttribute('href');
        if (href === '#') return;
        e.preventDefault();
        const target = document.querySelector(href);
        if (target) {
            window.scrollTo({ top: target.getBoundingClientRect().top + window.pageYOffset - 80, behavior: 'smooth' });
        }
    });
});
</script>
