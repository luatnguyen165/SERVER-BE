                    <div class="testimonial-author">
                        <div class="testimonial-avatar" style="background: linear-gradient(135deg, #0ea5e9, #0284c7);">TM</div>
                        <div>
                            <div class="testimonial-name">Trần Minh</div>
                            <div class="testimonial-role">Marketing Manager - ShopVN</div>
                        </div>
                    </div>
                </div>

