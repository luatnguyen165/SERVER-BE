<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bảng giá FB-SYSTEM - Gói dịch vụ chuyên nghiệp</title>
    <meta name="description" content="Bảng giá FB-SYSTEM với các gói Free, Pro, Enterprise. Tự động hóa marketing toàn diện cho mọi quy mô doanh nghiệp.">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/landing.css">
</head>
<body>
    <%- include('../partials/header') %>

    <!-- Pricing Hero -->
    <section class="pricing-hero section-padding" style="padding-top: 120px;">
        <div class="container">
            <div class="section-header">
                <div class="section-label"><i class="fas fa-tag"></i> Bảng giá</div>
                <h1 class="section-title">Chọn gói phù hợp với <span class="highlight">bạn</span></h1>
                <p class="section-subtitle">Tất cả gói đều bao gồm dùng thử 7 ngày. Nâng cấp bất kỳ lúc nào.</p>
            </div>
            <div class="pricing-toggle">
                <span class="toggle-label active" id="toggleMonthly">Thanh toán tháng</span>
                <label class="toggle-switch">
                    <input type="checkbox" id="billingToggle">
                    <span class="toggle-slider"></span>
                </label>
                <span class="toggle-label" id="toggleYearly">Thanh toán năm <span class="save-badge">Tiết kiệm 20%</span></span>
            </div>
        </div>
    </section>

    <!-- Pricing Cards -->
    <section class="section-padding pricing-section">
        <div class="container">
            <div class="pricing-grid">
                <!-- Free Plan -->
                <div class="pricing-card animate-on-scroll" data-plan="free">
                    <div class="pricing-badge">Miễn phí</div>
                    <div class="pricing-header">
                        <h3>Free</h3>
                        <p>Dành cho cá nhân bắt đầu</p>
                    </div>
                    <div class="pricing-amount">
                        <span class="price" data-monthly="0" data-yearly="0">0₫</span>
                        <span class="period">/tháng</span>
                    </div>
                    <ul class="pricing-features">
                        <li><i class="fas fa-check-circle"></i> Quản lý 1 kênh</li>
                        <li><i class="fas fa-check-circle"></i> Lên lịch 10 bài/tháng</li>
                        <li><i class="fas fa-check-circle"></i> AI Content cơ bản</li>
                        <li><i class="fas fa-times"></i> Auto Comment</li>
                        <li><i class="fas fa-times"></i> AI Scan nâng cao</li>
                        <li><i class="fas fa-times"></i> Phân tích chuyên sâu</li>
                        <li><i class="fas fa-times"></i> Ưu tiên hỗ trợ</li>
                    </ul>
                    <a href="/register" class="btn btn-outline btn-lg pricing-btn">Bắt đầu miễn phí</a>
                </div>

                <!-- Pro Plan (Featured) -->
                <div class="pricing-card pricing-featured animate-on-scroll" data-plan="pro">
                    <div class="pricing-badge popular">Phổ biến nhất</div>
                    <div class="pricing-header">
                        <h3>Pro</h3>
                        <p>Dành cho chuyên gia marketing</p>
                    </div>
                    <div class="pricing-amount">
                        <span class="price" data-monthly="299000" data-yearly="239000">299,000₫</span>
                        <span class="period">/tháng</span>
                    </div>
                    <ul class="pricing-features">
                        <li><i class="fas fa-check-circle"></i> Quản lý 5 kênh</li>
                        <li><i class="fas fa-check-circle"></i> Lên lịch không giới hạn</li>
                        <li><i class="fas fa-check-circle"></i> AI Content nâng cao</li>
                        <li><i class="fas fa-check-circle"></i> Auto Comment thông minh</li>
                        <li><i class="fas fa-check-circle"></i> AI Scan cơ bản</li>
                        <li><i class="fas fa-check-circle"></i> Phân tích chi tiết</li>
                        <li><i class="fas fa-times"></i> API ưu tiên</li>
                        <li><i class="fas fa-times"></i> Hỗ trợ 24/7</li>
                    </ul>
                    <a href="/register?plan=pro" class="btn btn-primary btn-lg pricing-btn">Dùng thử 7 ngày <i class="fas fa-arrow-right"></i></a>
                </div>

                <!-- Enterprise Plan -->
                <div class="pricing-card animate-on-scroll" data-plan="enterprise">
                    <div class="pricing-badge">Doanh nghiệp</div>
                    <div class="pricing-header">
                        <h3>Enterprise</h3>
                        <p>Dành cho tổ chức lớn</p>
                    </div>
                    <div class="pricing-amount">
                        <span class="price" data-monthly="999000" data-yearly="799000">999,000₫</span>
                        <span class="period">/tháng</span>
                    </div>
                    <ul class="pricing-features">
                        <li><i class="fas fa-check-circle"></i> Quản lý không giới hạn</li>
                        <li><i class="fas fa-check-circle"></i> Lên lịch không giới hạn</li>
                        <li><i class="fas fa-check-circle"></i> AI Content toàn diện</li>
                        <li><i class="fas fa-check-circle"></i> Auto Comment nâng cao</li>
                        <li><i class="fas fa-check-circle"></i> AI Scan toàn diện</li>
                        <li><i class="fas fa-check-circle"></i> Phân tích chuyên sâu</li>
                        <li><i class="fas fa-check-circle"></i> API ưu tiên</li>
                        <li><i class="fas fa-check-circle"></i> Hỗ trợ 24/7 riêng</li>
                        <li><i class="fas fa-check-circle"></i> Tùy chỉnh theo yêu cầu</li>
                    </ul>
                    <a href="/register?plan=enterprise" class="btn btn-outline btn-lg pricing-btn">Liên hệ tư vấn <i class="fas fa-phone"></i></a>
                </div>
            </div>
        </div>
    </section>

    <!-- Feature Comparison Table -->
    <section class="section-padding" style="background: var(--bg-secondary);">
        <div class="container">
            <div class="section-header">
                <div class="section-label"><i class="fas fa-table"></i> So sánh</div>
                <h2 class="section-title">So sánh chi tiết các <span class="highlight">gói</span></h2>
                <p class="section-subtitle">Xem chi tiết tính năng có trong từng gói dịch vụ.</p>
            </div>

            <div class="comparison-table-wrapper animate-on-scroll">
                <table class="comparison-table">
                    <thead>
                        <tr>
                            <th>Tính năng</th>
                            <th class="col-free">Free</th>
                            <th class="col-pro">Pro</th>
                            <th class="col-enterprise">Enterprise</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr><td>Số kênh quản lý</td><td>1 kênh</td><td>5 kênh</td><td>Không giới hạn</td></tr>
                        <tr><td>Lên lịch đăng bài</td><td>10/tháng</td><td>Không giới hạn</td><td>Không giới hạn</td></tr>
                        <tr><td>AI Tạo nội dung</td><td>Cơ bản</td><td>Nâng cao</td><td>Toàn diện</td></tr>
                        <tr><td>Auto Comment</td><td><i class="fas fa-times" style="color:var(--error)"></i></td><td><i class="fas fa-check" style="color:var(--success)"></i></td><td><i class="fas fa-check" style="color:var(--success)"></i></td></tr>
                        <tr><td>AI Scan</td><td><i class="fas fa-times" style="color:var(--error)"></i></td><td>Cơ bản</td><td>Toàn diện</td></tr>
                        <tr><td>Phân tích & Báo cáo</td><td>Cơ bản</td><td>Chi tiết</td><td>Chuyên sâu</td></tr>
                        <tr><td>Xuất dữ liệu</td><td>CSV</td><td>CSV, Excel, PDF</td><td>Tất cả định dạng</td></tr>
                        <tr><td>API Access</td><td><i class="fas fa-times" style="color:var(--error)"></i></td><td><i class="fas fa-times" style="color:var(--error)"></i></td><td><i class="fas fa-check" style="color:var(--success)"></i></td></tr>
                        <tr><td>Hỗ trợ</td><td>Email</td><td>Email + Chat</td><td>24/7 Priority</td></tr>
                        <tr><td>Dùng thử</td><td>Không giới hạn</td><td>7 ngày</td><td>7 ngày</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </section>

    <!-- FAQ -->
    <section class="section-padding" id="pricing-faq">
        <div class="container">
            <div class="section-header">
                <div class="section-label"><i class="fas fa-question-circle"></i> FAQ</div>
                <h2 class="section-title">Câu hỏi thường gặp về <span class="highlight">bảng giá</span></h2>
            </div>
            <div class="faq-grid" style="max-width: 800px; margin: 0 auto;">
                <div class="faq-item animate-on-scroll">
                    <div class="faq-question" onclick="this.parentElement.classList.toggle('active')">
                        <span>Tôi có thể nâng cấp hạ cấp gói bất kỳ lúc nào không?</span>
                        <i class="fas fa-chevron-down"></i>
                    </div>
                    <div class="faq-answer"><p>Có, bạn có thể nâng cấp hoặc hạ cấp gói bất kỳ lúc nào. Khi nâng cấp, bạn sẽ được tính phí theo tỷ lệ cho phần còn lại của tháng. Khi hạ cấp, gói mới sẽ có hiệu lực vào đầu kỳ thanh toán tiếp theo.</p></div>
                </div>
                <div class="faq-item animate-on-scroll">
                    <div class="faq-question" onclick="this.parentElement.classList.toggle('active')">
                        <span>Có chính sách hoàn tiền không?</span>
                        <i class="fas fa-chevron-down"></i>
                    </div>
                    <div class="faq-answer"><p>Chúng tôi có chính sách hoàn tiền trong vòng 7 ngày kể từ ngày thanh toán. Nếu bạn không hài lòng với dịch vụ, hãy liên hệ support để được hoàn tiền đầy đủ.</p></div>
                </div>
                <div class="faq-item animate-on-scroll">
                    <div class="faq-question" onclick="this.parentElement.classList.toggle('active')">
                        <span>Tôi có thể hủy gói bất kỳ lúc nào không?</span>
                        <i class="fas fa-chevron-down"></i>
                    </div>
                    <div class="faq-answer"><p>Có, bạn có thể hủy gói bất kỳ lúc nào. Dữ liệu của bạn sẽ được giữ nguyên cho đến cuối kỳ thanh toán. Sau đó tài khoản sẽ chuyển về gói Free.</p></div>
                </div>
                <div class="faq-item animate-on-scroll">
                    <div class="faq-question" onclick="this.parentElement.classList.toggle('active')">
                        <span>Có ưu đãi cho startup hoặc tổ chức phi lợi nhuận không?</span>
                        <i class="fas fa-chevron-down"></i>
                    </div>
                    <div class="faq-answer"><p>Có, chúng tôi có chương trình hỗ trợ đặc biệt cho startup và tổ chức phi lợi nhuận. Vui lòng liên hệ với đội ngũ bán hàng để biết thêm chi tiết.</p></div>
                </div>
                <div class="faq-item animate-on-scroll">
                    <div class="faq-question" onclick="this.parentElement.classList.toggle('active')">
                        <span>Tôi có thể thanh toán bằng những phương thức nào?</span>
                        <i class="fas fa-chevron-down"></i>
                    </div>
                    <div class="faq-answer"><p>Chúng tôi hỗ trợ thanh toán qua thẻ tín dụng/thẻ ghi nợ (Visa, Mastercard), chuyển khoản ngân hàng, Momo, ZaloPay, và Vietcombank.</p></div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="section-padding">
        <div class="container">
            <div class="cta-section">
                <div class="cta-content">
                    <h2>Bắt đầu với <span class="highlight">FB-SYSTEM</span> ngay hôm nay</h2>
                    <p>Dùng thử 7 ngày miễn phí với tất cả tính năng Pro. Không cần thẻ tín dụng.</p>
                    <div class="cta-buttons">
                        <a href="/register" class="btn btn-primary btn-lg">Bắt đầu dùng thử <i class="fas fa-arrow-right"></i></a>
                        <a href="/#contact" class="btn btn-outline btn-lg">Tư vấn miễn phí</a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <%- include('../partials/footer') %>

    <script>
        // Billing toggle
        const billingToggle = document.getElementById('billingToggle');
        const toggleMonthly = document.getElementById('toggleMonthly');
        const toggleYearly = document.getElementById('toggleYearly');

        billingToggle.addEventListener('change', function() {
            const isYearly = this.checked;
            document.querySelectorAll('.price').forEach(el => {
                const monthly = parseInt(el.dataset.monthly);
                const yearly = parseInt(el.dataset.yearly);
                if (isYearly) {
                    el.textContent = yearly.toLocaleString('vi-VN') + '₫';
                    el.closest('.pricing-amount').querySelector('.period').textContent = '/tháng (thanh toán năm)';
                } else {
                    el.textContent = monthly.toLocaleString('vi-VN') + '₫';
                    el.closest('.pricing-amount').querySelector('.period').textContent = '/tháng';
                }
            });
            toggleMonthly.classList.toggle('active', !isYearly);
            toggleYearly.classList.toggle('active', isYearly);
        });

        // Scroll animations
        function handleScrollAnimations() {
            document.querySelectorAll('.animate-on-scroll').forEach(el => {
                const rect = el.getBoundingClientRect();
                if (rect.top < window.innerHeight - 100 && rect.bottom > 0) {
                    el.classList.add('visible');
                }
            });
        }
        window.addEventListener('scroll', handleScrollAnimations);
        window.addEventListener('load', handleScrollAnimations);
    </script>
</body>
</html>