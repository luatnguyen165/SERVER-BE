<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tài liệu hướng dẫn - FB-SYSTEM</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="/css/landing.css">
    <style>
        /* ================================================
           DOCS PAGE - Consistent with FB-SYSTEM Design System
           All colors use CSS custom properties from landing.css
           ================================================ */

        /* --- Color Tokens (local overrides for dark hero) --- */
        :root {
            --docs-icon-bg-primary: var(--primary-bg);
            --docs-icon-bg-success: rgba(16, 185, 129, 0.12);
            --docs-icon-bg-info: rgba(59, 130, 246, 0.12);
            --docs-icon-bg-warning: rgba(245, 158, 11, 0.12);
            --docs-icon-bg-error: rgba(239, 68, 68, 0.12);
            --docs-icon-bg-teal: rgba(13, 148, 136, 0.12);
            --docs-icon-color-primary: var(--primary);
            --docs-icon-color-success: var(--success);
            --docs-icon-color-info: #2563eb;
            --docs-icon-color-warning: #d97706;
            --docs-icon-color-error: #dc2626;
            --docs-icon-color-teal: #0d9488;
        }

        .docs-page {
            padding-top: var(--header-height);
            min-height: 100vh;
            background: var(--bg-secondary);
        }

        /* --- Docs Hero --- */
        .docs-hero {
            background: linear-gradient(135deg, var(--dark) 0%, var(--dark-2) 100%);
            padding: 80px 0 60px;
            position: relative;
            overflow: hidden;
        }

        .docs-hero::before {
            content: '';
            position: absolute;
            inset: 0;
            background-image: radial-gradient(rgba(99, 102, 241, 0.12) 1px, transparent 1px);
            background-size: 30px 30px;
        }

        .docs-hero-glow {
            position: absolute;
            width: 400px;
            height: 400px;
            border-radius: 50%;
            filter: blur(100px);
            opacity: 0.2;
        }
        .docs-hero-glow-1 { background: var(--primary); top: -100px; right: -100px; }
        .docs-hero-glow-2 { background: var(--secondary); bottom: -150px; left: -100px; }

        .docs-hero-content {
            position: relative;
            z-index: 1;
            text-align: center;
        }

        .docs-hero h1 {
            font-size: clamp(2rem, 4vw, 2.8rem);
            font-weight: 800;
            color: white;
            margin-bottom: 12px;
        }

        .docs-hero h1 i {
            background: var(--primary-gradient);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .docs-hero p {
            color: rgba(255,255,255,0.7);
            font-size: 1.1rem;
            max-width: 600px;
            margin: 0 auto 32px;
            line-height: 1.7;
        }

        /* --- Search Bar --- */
        .docs-search {
            max-width: 560px;
            margin: 0 auto;
            position: relative;
        }

        .docs-search input {
            width: 100%;
            padding: 16px 20px 16px 52px;
            border-radius: var(--radius-lg);
            border: 1px solid rgba(255,255,255,0.1);
            background: rgba(255,255,255,0.08);
            backdrop-filter: blur(10px);
            color: white;
            font-size: 15px;
            transition: all var(--transition);
        }

        .docs-search input::placeholder { color: rgba(255,255,255,0.4); }
        .docs-search input:focus {
            border-color: var(--primary-light);
            background: rgba(255,255,255,0.12);
            box-shadow: 0 0 30px rgba(99, 102, 241, 0.15);
            outline: none;
        }

        .docs-search i {
            position: absolute;
            left: 20px;
            top: 50%;
            transform: translateY(-50%);
            color: rgba(255,255,255,0.4);
            font-size: 18px;
        }

        .docs-search .search-shortcut {
            position: absolute;
            right: 16px;
            top: 50%;
            transform: translateY(-50%);
            padding: 3px 8px;
            background: rgba(255,255,255,0.1);
            border-radius: 4px;
            font-size: 11px;
            color: rgba(255,255,255,0.4);
            font-family: var(--font-mono);
        }

        /* --- Docs Layout --- */
        .docs-layout {
            display: grid;
            grid-template-columns: 280px 1fr;
            gap: 40px;
            max-width: var(--max-width);
            margin: 0 auto;
            padding: 40px 24px 80px;
        }

        /* --- Sidebar Navigation --- */
        .docs-sidebar {
            position: sticky;
            top: calc(var(--header-height) + 24px);
            height: fit-content;
            max-height: calc(100vh - var(--header-height) - 48px);
            overflow-y: auto;
            padding-right: 8px;
        }

        .docs-sidebar::-webkit-scrollbar { width: 4px; }
        .docs-sidebar::-webkit-scrollbar-track { background: transparent; }
        .docs-sidebar::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }

        .docs-nav-group {
            margin-bottom: 28px;
        }

        .docs-nav-group-title {
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1.2px;
            color: var(--text-muted);
            margin-bottom: 10px;
            padding-left: 12px;
        }

        .docs-nav-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 12px;
            border-radius: var(--radius-md);
            color: var(--text-secondary);
            font-size: 14px;
            font-weight: 500;
            transition: all var(--transition);
            cursor: pointer;
            text-decoration: none;
        }

        .docs-nav-item i {
            width: 18px;
            text-align: center;
            font-size: 13px;
            color: var(--text-muted);
            transition: color var(--transition);
        }

        .docs-nav-item:hover {
            background: var(--bg-tertiary);
            color: var(--primary);
        }

        .docs-nav-item:hover i {
            color: var(--primary);
        }

        .docs-nav-item.active {
            background: var(--primary-bg);
            color: var(--primary);
            font-weight: 600;
        }

        .docs-nav-item.active i {
            color: var(--primary);
        }

        .docs-nav-item .nav-badge {
            margin-left: auto;
            padding: 2px 8px;
            border-radius: var(--radius-full);
            font-size: 10px;
            font-weight: 600;
            background: var(--primary-bg);
            color: var(--primary);
        }

        .docs-nav-item .nav-badge.green {
            background: var(--docs-icon-bg-success);
            color: var(--docs-icon-color-success);
        }

        .docs-nav-item .nav-badge.orange {
            background: var(--docs-icon-bg-warning);
            color: var(--docs-icon-color-warning);
        }

        /* --- Main Content --- */
        .docs-content {
            min-width: 0;
        }

        .docs-section {
            margin-bottom: 60px;
            scroll-margin-top: calc(var(--header-height) + 24px);
        }

        .docs-section:last-child {
            margin-bottom: 0;
        }

        .docs-section-header {
            margin-bottom: 32px;
            padding-bottom: 20px;
            border-bottom: 1px solid var(--border);
        }

        .docs-section-header h2 {
            font-size: 1.8rem;
            font-weight: 800;
            color: var(--text-primary);
            margin-bottom: 8px;
        }

        .docs-section-header h2 i {
            color: var(--primary);
            margin-right: 10px;
        }

        .docs-section-header p {
            color: var(--text-secondary);
            font-size: 1rem;
        }

        /* --- Article Card --- */
        .docs-article {
            background: white;
            border-radius: var(--radius-lg);
            border: 1px solid var(--border);
            padding: 32px;
            margin-bottom: 20px;
            transition: all var(--transition);
            position: relative;
            overflow: hidden;
        }

        .docs-article::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: var(--primary-gradient);
            transform: scaleX(0);
            transform-origin: left;
            transition: transform var(--transition);
        }

        .docs-article:hover {
            box-shadow: var(--shadow-lg);
            border-color: transparent;
            transform: translateY(-2px);
        }

        .docs-article:hover::before {
            transform: scaleX(1);
        }

        .docs-article-header {
            display: flex;
            align-items: flex-start;
            gap: 16px;
            margin-bottom: 16px;
        }

        .docs-article-icon {
            width: 48px;
            height: 48px;
            border-radius: var(--radius-md);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            flex-shrink: 0;
        }

        .docs-article-icon.purple {
            background: var(--docs-icon-bg-primary);
            color: var(--docs-icon-color-primary);
        }
        .docs-article-icon.green {
            background: var(--docs-icon-bg-success);
            color: var(--docs-icon-color-success);
        }
        .docs-article-icon.blue {
            background: var(--docs-icon-bg-info);
            color: var(--docs-icon-color-info);
        }
        .docs-article-icon.orange {
            background: var(--docs-icon-bg-warning);
            color: var(--docs-icon-color-warning);
        }
        .docs-article-icon.red {
            background: var(--docs-icon-bg-error);
            color: var(--docs-icon-color-error);
        }
        .docs-article-icon.teal {
            background: var(--docs-icon-bg-teal);
            color: var(--docs-icon-color-teal);
        }

        .docs-article-title {
            flex: 1;
        }

        .docs-article-title h3 {
            font-size: 1.1rem;
            font-weight: 700;
            color: var(--text-primary);
            margin-bottom: 4px;
        }

        .docs-article-title .article-meta {
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 12px;
            color: var(--text-muted);
        }

        .docs-article-title .article-meta span {
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .docs-article p {
            color: var(--text-secondary);
            font-size: 0.95rem;
            line-height: 1.7;
            margin-bottom: 16px;
        }

        .docs-article .article-tags {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-top: 16px;
        }

        .docs-article .article-tag {
            padding: 4px 12px;
            border-radius: var(--radius-full);
            font-size: 11px;
            font-weight: 600;
            background: var(--bg-tertiary);
            color: var(--text-secondary);
            transition: all var(--transition);
            cursor: default;
        }

        .docs-article .article-tag:hover {
            background: var(--primary-bg);
            color: var(--primary);
        }

        .docs-article .article-link {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-size: 14px;
            font-weight: 600;
            color: var(--primary);
            transition: gap var(--transition);
        }

        .docs-article .article-link:hover {
            gap: 10px;
        }

        /* --- Quick Start Cards --- */
        .quick-start-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 16px;
            margin-bottom: 32px;
        }

        .quick-start-card {
            background: white;
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            padding: 24px;
            text-align: center;
            transition: all var(--transition);
            cursor: pointer;
        }

        .quick-start-card:hover {
            box-shadow: var(--shadow-lg);
            border-color: transparent;
            transform: translateY(-4px);
        }

        .quick-start-card .qs-icon {
            width: 56px;
            height: 56px;
            border-radius: var(--radius-md);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            margin: 0 auto 16px;
        }

        .quick-start-card .qs-icon.purple {
            background: var(--docs-icon-bg-primary);
            color: var(--docs-icon-color-primary);
        }
        .quick-start-card .qs-icon.green {
            background: var(--docs-icon-bg-success);
            color: var(--docs-icon-color-success);
        }
        .quick-start-card .qs-icon.blue {
            background: var(--docs-icon-bg-info);
            color: var(--docs-icon-color-info);
        }
        .quick-start-card .qs-icon.orange {
            background: var(--docs-icon-bg-warning);
            color: var(--docs-icon-color-warning);
        }
        .quick-start-card .qs-icon.teal {
            background: var(--docs-icon-bg-teal);
            color: var(--docs-icon-color-teal);
        }

        .quick-start-card h4 {
            font-size: 1rem;
            font-weight: 700;
            color: var(--text-primary);
            margin-bottom: 8px;
        }

        .quick-start-card p {
            font-size: 0.85rem;
            color: var(--text-secondary);
            line-height: 1.6;
        }

        /* --- Code Block --- */
        .docs-code-block {
            background: var(--dark);
            border-radius: var(--radius-lg);
            overflow: hidden;
            margin: 20px 0;
            border: 1px solid rgba(255,255,255,0.05);
        }

        .docs-code-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 12px 20px;
            background: rgba(255,255,255,0.03);
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }

        .docs-code-header .code-lang {
            font-size: 12px;
            font-weight: 600;
            color: rgba(255,255,255,0.4);
            font-family: var(--font-mono);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .docs-code-header .code-copy {
            display: flex;
            align-items: center;
            gap: 6px;
            padding: 4px 12px;
            border-radius: 6px;
            background: rgba(255,255,255,0.06);
            color: rgba(255,255,255,0.5);
            font-size: 12px;
            cursor: pointer;
            transition: all var(--transition);
            border: none;
        }

        .docs-code-header .code-copy:hover {
            background: rgba(255,255,255,0.1);
            color: white;
        }

        .docs-code-block pre {
            padding: 20px;
            overflow-x: auto;
            margin: 0;
        }

        .docs-code-block code {
            font-family: var(--font-mono);
            font-size: 13px;
            line-height: 1.7;
            color: #e2e8f0;
        }

        /* Syntax highlighting (using design system colors) */
        .docs-code-block .comment { color: var(--text-muted); }
        .docs-code-block .keyword { color: var(--primary-light); }
        .docs-code-block .string { color: var(--success); }
        .docs-code-block .function { color: var(--secondary); }
        .docs-code-block .number { color: #f472b6; }
        .docs-code-block .variable { color: var(--accent); }
        .docs-code-block .operator { color: var(--error); }

        /* --- Info Boxes --- */
        .docs-info-box {
            display: flex;
            align-items: flex-start;
            gap: 14px;
            padding: 20px;
            border-radius: var(--radius-md);
            margin: 20px 0;
            border: 1px solid;
        }

        .docs-info-box.info {
            background: var(--docs-icon-bg-primary);
            border-color: rgba(99, 102, 241, 0.2);
        }
        .docs-info-box.warning {
            background: var(--docs-icon-bg-warning);
            border-color: rgba(245, 158, 11, 0.2);
        }
        .docs-info-box.success {
            background: var(--docs-icon-bg-success);
            border-color: rgba(16, 185, 129, 0.2);
        }
        .docs-info-box.error {
            background: var(--docs-icon-bg-error);
            border-color: rgba(239, 68, 68, 0.2);
        }

        .docs-info-box i {
            font-size: 18px;
            flex-shrink: 0;
            margin-top: 2px;
        }

        .docs-info-box.info i { color: var(--primary); }
        .docs-info-box.warning i { color: var(--warning); }
        .docs-info-box.success i { color: var(--success); }
        .docs-info-box.error i { color: var(--error); }

        .docs-info-box p {
            margin: 0;
            font-size: 0.9rem;
            line-height: 1.6;
        }

        .docs-info-box.info p { color: var(--docs-icon-color-primary); }
        .docs-info-box.warning p { color: var(--docs-icon-color-warning); }
        .docs-info-box.success p { color: var(--docs-icon-color-success); }
        .docs-info-box.error p { color: var(--docs-icon-color-error); }

        /* --- Step List --- */
        .docs-step-list {
            counter-reset: step;
            margin: 20px 0;
        }

        .docs-step-item {
            display: flex;
            gap: 16px;
            padding: 20px;
            background: white;
            border: 1px solid var(--border);
            border-radius: var(--radius-md);
            margin-bottom: 12px;
            transition: all var(--transition);
        }

        .docs-step-item:hover {
            border-color: var(--primary-light);
            box-shadow: var(--shadow-sm);
        }

        .docs-step-number {
            counter-increment: step;
            width: 36px;
            height: 36px;
            border-radius: var(--radius-full);
            background: var(--primary-gradient);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            font-weight: 700;
            flex-shrink: 0;
        }

        .docs-step-item .step-content {
            flex: 1;
        }

        .docs-step-item .step-content h4 {
            font-size: 1rem;
            font-weight: 700;
            color: var(--text-primary);
            margin-bottom: 6px;
        }

        .docs-step-item .step-content p {
            font-size: 0.9rem;
            color: var(--text-secondary);
            line-height: 1.6;
            margin: 0;
        }

        /* --- FAQ Accordion --- */
        .docs-faq-item {
            background: white;
            border: 1px solid var(--border);
            border-radius: var(--radius-md);
            margin-bottom: 10px;
            overflow: hidden;
            transition: all var(--transition);
        }

        .docs-faq-question {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 18px 20px;
            cursor: pointer;
            transition: background var(--transition);
            gap: 16px;
        }

        .docs-faq-question:hover {
            background: var(--bg-secondary);
        }

        .docs-faq-question h4 {
            font-size: 0.95rem;
            font-weight: 600;
            color: var(--text-primary);
            margin: 0;
            flex: 1;
        }

        .docs-faq-question .faq-toggle {
            width: 28px;
            height: 28px;
            border-radius: var(--radius-full);
            background: var(--bg-tertiary);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            color: var(--text-muted);
            transition: all var(--transition);
            flex-shrink: 0;
        }

        .docs-faq-item.active .faq-toggle {
            background: var(--primary-bg);
            color: var(--primary);
            transform: rotate(180deg);
        }

        .docs-faq-answer {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.3s ease, padding 0.3s ease;
            padding: 0 20px;
        }

        .docs-faq-item.active .docs-faq-answer {
            max-height: 300px;
            padding: 0 20px 20px;
        }

        .docs-faq-answer p {
            font-size: 0.9rem;
            color: var(--text-secondary);
            line-height: 1.7;
            margin: 0;
        }

        /* --- Table --- */
        .docs-table-wrapper {
            overflow-x: auto;
            margin: 20px 0;
            border-radius: var(--radius-md);
            border: 1px solid var(--border);
        }

        .docs-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.9rem;
        }

        .docs-table th {
            background: var(--bg-secondary);
            padding: 14px 20px;
            text-align: left;
            font-weight: 600;
            color: var(--text-primary);
            border-bottom: 1px solid var(--border);
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .docs-table td {
            padding: 14px 20px;
            border-bottom: 1px solid var(--border-light);
            color: var(--text-secondary);
        }

        .docs-table tr:last-child td {
            border-bottom: none;
        }

        .docs-table tr:hover td {
            background: var(--bg-secondary);
        }

        .docs-table .status-badge {
            padding: 3px 10px;
            border-radius: var(--radius-full);
            font-size: 11px;
            font-weight: 600;
        }

        .docs-table .status-badge.done {
            background: var(--docs-icon-bg-success);
            color: var(--docs-icon-color-success);
        }
        .docs-table .status-badge.beta {
            background: var(--docs-icon-bg-warning);
            color: var(--docs-icon-color-warning);
        }
        .docs-table .status-badge.new {
            background: var(--docs-icon-bg-info);
            color: var(--docs-icon-color-info);
        }

        /* --- Resource Links --- */
        .docs-resources {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 16px;
            margin: 20px 0;
        }

        .docs-resource-card {
            background: white;
            border: 1px solid var(--border);
            border-radius: var(--radius-md);
            padding: 20px;
            text-align: center;
            transition: all var(--transition);
            text-decoration: none;
            display: block;
        }

        .docs-resource-card:hover {
            box-shadow: var(--shadow-md);
            border-color: var(--primary-light);
            transform: translateY(-2px);
        }

        .docs-resource-card i {
            font-size: 28px;
            color: var(--primary);
            margin-bottom: 12px;
        }

        .docs-resource-card h4 {
            font-size: 0.95rem;
            font-weight: 700;
            color: var(--text-primary);
            margin-bottom: 6px;
        }

        .docs-resource-card p {
            font-size: 0.8rem;
            color: var(--text-muted);
            margin: 0;
            line-height: 1.5;
        }

        /* --- Table of Contents (On This Page) --- */
        .docs-toc {
            background: white;
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            padding: 20px;
            margin-bottom: 24px;
        }

        .docs-toc-title {
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--text-muted);
            margin-bottom: 12px;
        }

        .docs-toc-list {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        .docs-toc-item {
            padding: 6px 12px;
            border-radius: 6px;
            font-size: 13px;
            color: var(--text-secondary);
            transition: all var(--transition);
            cursor: pointer;
            text-decoration: none;
            border-left: 2px solid transparent;
        }

        .docs-toc-item:hover {
            color: var(--primary);
            background: var(--primary-bg);
            border-left-color: var(--primary);
        }

        /* --- Pagination --- */
        .docs-pagination {
            display: flex;
            justify-content: space-between;
            gap: 16px;
            margin-top: 60px;
            padding-top: 32px;
            border-top: 1px solid var(--border);
        }

        .docs-pagination a {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 14px 20px;
            border-radius: var(--radius-md);
            border: 1px solid var(--border);
            transition: all var(--transition);
            text-decoration: none;
            max-width: 45%;
        }

        .docs-pagination a:hover {
            border-color: var(--primary-light);
            box-shadow: var(--shadow-sm);
        }

        .docs-pagination a.prev { text-align: left; }
        .docs-pagination a.next { text-align: right; }

        .docs-pagination .pag-label {
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: var(--text-muted);
        }

        .docs-pagination .pag-title {
            font-size: 14px;
            font-weight: 600;
            color: var(--text-primary);
        }

        /* --- Responsive --- */
        @media (max-width: 1024px) {
            .docs-layout {
                grid-template-columns: 1fr;
            }
            .docs-sidebar {
                position: relative;
                top: 0;
                max-height: none;
                overflow: visible;
                display: grid;
                grid-template-columns: repeat(2, 1fr);
                gap: 16px;
                padding: 0;
            }
            .docs-nav-group-title { padding-left: 0; }
            .docs-sidebar::-webkit-scrollbar { display: none; }
        }

        @media (max-width: 768px) {
            .docs-hero { padding: 60px 0 40px; }
            .docs-layout { padding: 24px 16px 60px; gap: 24px; }
            .docs-sidebar { grid-template-columns: 1fr; }
            .docs-article { padding: 20px; }
            .docs-article-header { flex-direction: column; }
            .quick-start-grid { grid-template-columns: 1fr; }
            .docs-resources { grid-template-columns: 1fr; }
            .docs-pagination { flex-direction: column; }
            .docs-pagination a { max-width: 100%; }
            .docs-section-header h2 { font-size: 1.4rem; }
            .docs-step-item { flex-direction: column; align-items: flex-start; }
        }

        @media (max-width: 480px) {
            .docs-table th,
            .docs-table td {
                padding: 10px 14px;
                font-size: 0.8rem;
            }
        }

        /* --- Scroll Animations --- */
        .docs-section {
            opacity: 0;
            transform: translateY(20px);
            transition: opacity 0.6s ease, transform 0.6s ease;
        }

        .docs-section.visible {
            opacity: 1;
            transform: translateY(0);
        }
    </style>
</head>
<body>

