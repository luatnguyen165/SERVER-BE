            <!-- Main Content -->
            <div class="docs-content" id="docsContent">

                <!-- Quick Start -->
                <section id="quick-start" class="docs-section">
                    <div class="docs-section-header">
                        <h2><i class="fas fa-rocket"></i> Bắt đầu nhanh</h2>
                        <p>Làm quen với FB-SYSTEM trong vài phút. Chọn hướng dẫn phù hợp với nhu cầu của bạn.</p>
                    </div>

                    <div class="quick-start-grid">
                        <a href="#installation" class="quick-start-card">
                            <div class="qs-icon purple"><i class="fas fa-download"></i></div>
                            <h4>Cài đặt ứng dụng</h4>
                            <p>Tải và cài đặt FB-SYSTEM trên Windows/macOS chỉ với vài bước đơn giản.</p>
                        </a>
                        <a href="#account" class="quick-start-card">
