    <script>
        // ========================================
        // DOCS PAGE INTERACTIONS
        // ========================================

        // --- Smooth scroll & active nav ---
        document.querySelectorAll('.docs-nav-item').forEach(item => {
            item.addEventListener('click', function(e) {
                e.preventDefault();
                const targetId = this.getAttribute('href').substring(1);
                const target = document.getElementById(targetId);
                if (target) {
                    const offset = 100;
                    const top = target.getBoundingClientRect().top + window.scrollY - offset;
                    window.scrollTo({ top, behavior: 'smooth' });
                }
                // Update active
                document.querySelectorAll('.docs-nav-item').forEach(i => i.classList.remove('active'));
                this.classList.add('active');
            });
        });

        // --- Update active nav on scroll ---
        const sections = document.querySelectorAll('.docs-section');
        const navItems = document.querySelectorAll('.docs-nav-item');

        function updateActiveNav() {
            let current = '';
            sections.forEach(section => {
                const rect = section.getBoundingClientRect();
                if (rect.top <= 150) {
                    current = section.getAttribute('id');
                }
            });

            navItems.forEach(item => {
                item.classList.remove('active');
                if (item.getAttribute('data-section') === current) {
                    item.classList.add('active');
                }
            });
        }

        window.addEventListener('scroll', updateActiveNav, { passive: true });

        // --- Section reveal animation ---
        const sectionObserver = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('visible');
                    sectionObserver.unobserve(entry.target);
                }
            });
        }, { threshold: 0.1 });

        document.querySelectorAll('.docs-section').forEach(s => sectionObserver.observe(s));

        // --- FAQ Toggle ---
        function toggleFaq(element) {
            element.classList.toggle('active');
        }

        // Make toggleFaq globally available
        window.toggleFaq = toggleFaq;

        // --- Code Copy ---
        function copyCode(btn) {
            const code = btn.closest('.docs-code-block').querySelector('code');
            if (code) {
                navigator.clipboard.writeText(code.textContent).then(() => {
                    const original = btn.innerHTML;
                    btn.innerHTML = '<i class="fas fa-check"></i> Đã copy';
                    btn.style.color = '#34d399';
                    setTimeout(() => {
                        btn.innerHTML = original;
                        btn.style.color = '';
                    }, 2000);
                });
            }
        }

        window.copyCode = copyCode;

        // --- Search functionality ---
        const searchInput = document.getElementById('docsSearch');
        if (searchInput) {
            searchInput.addEventListener('input', function() {
                const query = this.value.toLowerCase().trim();
                const articles = document.querySelectorAll('.docs-article, .quick-start-card, .docs-faq-item, .docs-step-item');

                articles.forEach(article => {
                    const text = article.textContent.toLowerCase();
                    if (!query) {
                        article.style.display = '';
                        article.style.opacity = '1';
                    } else if (text.includes(query)) {
                        article.style.display = '';
                        article.style.opacity = '1';
                        // Highlight matching sections
                        const parent = article.closest('.docs-section');
                        if (parent) parent.style.opacity = '1';
                    } else {
                        article.style.display = 'none';
                    }
                });

                // Show/hide sections based on visible children
                document.querySelectorAll('.docs-section').forEach(section => {
                    const visible = Array.from(section.querySelectorAll('.docs-article, .quick-start-card, .docs-faq-item, .docs-step-item'))
                        .some(el => el.style.display !== 'none');
                    section.style.display = visible || !query ? '' : 'none';
                });
            });
        }

        // --- Keyboard shortcut ---
        document.addEventListener('keydown', function(e) {
            if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
                e.preventDefault();
                searchInput?.focus();
            }
            if (e.key === 'Escape') {
                searchInput?.blur();
            }
        });

        // --- Stagger animation for step items ---
        const stepObserver = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    const delay = parseInt(entry.target.dataset.delay) || 0;
                    setTimeout(() => {
                        entry.target.style.opacity = '1';
                        entry.target.style.transform = 'translateY(0)';
                    }, delay);
                    stepObserver.unobserve(entry.target);
                }
            });
        }, { threshold: 0.1 });

        document.querySelectorAll('.docs-step-item').forEach(item => {
            item.style.opacity = '0';
            item.style.transform = 'translateY(20px)';
            item.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
            stepObserver.observe(item);
        });

        console.log('📄 Docs page initialized');
    </script>
</body>
